---
import Layout from "@layouts/BlankLayout.astro";
import "@legacy-dependencies/load-awesome-v1/css/ball-pulse.css";
import "./_internal/index.css";

import favicon from "./_internal/assets/mgp.png";
import icon128x128 from "./_internal/assets/mgp-enlarged-for-touch-128x128.png";
import icon152x152 from "./_internal/assets/mgp-enlarged-for-touch-152x152.png";
---

<Layout
    title="FFXIV Mini Cactpot Solver"
    description="Perfect mini-cactpot games in as few clicks as possible."
    keywords={["FFXIV", "Final Fantasy XIV", "Mini Cactpot", "Solver", "Calculator", "Perfect"]}
    faviconPath={favicon.src}
    suppressDefaultViewport
>
    <Fragment slot="head">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link href={icon128x128.src} rel="icon" sizes="128x128">
        <link href={icon152x152.src} rel="icon" sizes="152x152">
        <link href={icon152x152.src} rel="apple-touch-icon">
        <link href={icon152x152.src} rel="apple-touch-icon" sizes="152x152">

        <!-- TODO investigate whether we need to figure out preloading for performance -->
        <!--
        <link rel="preload" as="font" crossorigin="anonymous" href="/common-dependencies/inconsolata-font/Inconsolata-VariableFont_wdth,wght.ttf">
        <link rel="preload" as="script" crossorigin="anonymous" href="./_internal/algorithm.js">
        <link rel="preload" as="script" crossorigin="anonymous" href="./_internal/hardcoded.js">
        <link rel="preload" as="script" crossorigin="anonymous" href="./_internal/index.js">
        <link rel="prefetch" as="script" crossorigin="anonymous" href="./_internal/worker.js">
        <link rel="prefetch" as="image" href="/common-dependencies/fontawesome-free-v6-web/sprites/regular.svg">
        -->
    </Fragment>

    <div class="app-simple-mode" id="app">
        <div class="app-section" id="app-left">
            <div id="playarea">
                <div class="cell" id="cell-a"></div>
                <div class="cell" id="cell-b"></div>
                <div class="cell" id="cell-c"></div>
                <div class="cell" id="cell-d"></div>
                <div class="cell" id="cell-e"></div>

                <div class="cell" id="cell-f"></div>
                <div class="cell" id="cell-0"></div>
                <div class="cell" id="cell-1"></div>
                <div class="cell" id="cell-2"></div>
                <div class="cell" id="info-cell">
                    <div>
                        Expected/avg. rewards shown.<br><br>
                        Payouts are configurable using the table on the right.
                    </div>
                </div>

                <div class="cell" id="cell-g"></div>
                <div class="cell" id="cell-3"></div>
                <div class="cell" id="cell-4"></div>
                <div class="cell" id="cell-5"></div>
                <div class="cell" id="advanced-cell">
                    <div id="advanced-button" class="button icon-in-cell">
                        <div><svg><use href="/common-dependencies/fontawesome-free-v6-web/sprites/solid.svg#hashtag"></use></svg></div>
                    </div>
                </div>

                <div class="cell" id="cell-h"></div>
                <div class="cell" id="cell-6"></div>
                <div class="cell" id="cell-7"></div>
                <div class="cell" id="cell-8"></div>
                <div class="cell" id="reset-cell">
                    <div id="reset-button" class="button icon-in-cell">
                        <div><svg><use href="/common-dependencies/fontawesome-free-v6-web/sprites/solid.svg#arrow-rotate-right"></use></svg></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="app-section" id="app-right">
            <div id="payouts-disp">
                <div></div>
            </div>
        </div>
    </div>

    <script>
        import "./_internal/index.js";
    </script>
</Layout>

