---
import {
    AUTHOR,
    SOURCE_CODE_URL,
} from "@root/constants";

const copyrightYear = new Date().getFullYear();
---

<footer id="footer" class="content-column">
    <p id="footer-text">
        &copy; {copyrightYear} {AUTHOR}. All content on this site is licensed under <a href="https://www.gnu.org/licenses/agpl-3.0.en.html" target="_blank" rel="license noopener noreferrer" style="display:inline-block;">GNU Affero General Public License v3.0</a>.
        <br />
        This site's source code is available on <a href={SOURCE_CODE_URL}>GitHub</a>.
    </p>
</footer>

